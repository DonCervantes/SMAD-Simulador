# SPEC §13 — required environment variables
# Copy to .env.local and fill in. Never commit .env.local.

# Privy — auth provider (client + server)
# Get from https://dashboard.privy.io/ → Apps → your app → Settings
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Supabase — Postgres + RLS
# Get from https://supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
